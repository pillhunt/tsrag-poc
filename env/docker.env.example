# PoC — шаблон переменных для docker-compose.yml
# Скопируйте:  copy env\docker.env.example env\docker.env
# Запуск:     .\compose.ps1 up --build
#             docker compose --env-file env/docker.env up --build
# Сеть shared-network должна существовать:  docker network create shared-network

# Порт PoC на хосте (в контейнере incident-intent-poc всегда 8090)
TSRAG_PORT=8090

# --- Тома ---
# Логи: каталоги выгрузки в ./logs (в compose: ./logs → /app/logs)
# Caseone: папка на хосте → в контейнере всегда /caseone; в форме только /caseone/…
CASEONE_HOST_DIR=D:\Work\Dev\79

# --- GPU для сервиса ollama (опционально) ---
# Индекс GPU на хосте; для CPU-only можно оставить 0 и пустой NVIDIA_VISIBLE_DEVICES
CUDA_VISIBLE_DEVICES=0
# UUID или индекс GPU для Docker (пусто = не привязывать к конкретному устройству)
NVIDIA_VISIBLE_DEVICES=

# --- Ollama (сервис ollama + ollama-init в compose) ---
# URL API Ollama для PoC и ollama-init (имя хоста = имя сервиса в docker-compose)
OLLAMA_BASE_URL=http://ollama:11434
# Проброс порта Ollama на хост (внутри контейнера ollama всегда слушает 11434)
OLLAMA_PORT=11434
# Адрес bind внутри контейнера ollama (передаётся в OLLAMA_HOST)
OLLAMA_LISTEN=0.0.0.0:11434
# Модель: ollama-init выполнит pull; PoC использует её в шагах 0 и 6
# q4_K_M ~6 GiB RAM; q6_K — заметно больше, нужен запас по памяти
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
# Таймаут HTTP-запросов PoC к Ollama, секунды (длинные ответы LLM)
OLLAMA_TIMEOUT_SEC=3600
# Размер контекста (num_ctx): больше — длиннее промпт, но выше расход RAM
OLLAMA_NUM_CTX=8192

# --- Confluence (Wiki / playbook) ---
# Пустой CONFLUENCE_URL — шаг Confluence пропускается, только полный разбор + LLM
CONFLUENCE_URL=
# true = Cloud (API token), false = Server / Data Center
CONFLUENCE_CLOUD=false
CONFLUENCE_USERNAME=
CONFLUENCE_TOKEN=
# Server/DC: альтернатива паролю — Personal Access Token
CONFLUENCE_PAT=
# Ограничить поиск одним space (например SUPPORT)
CONFLUENCE_SPACE_KEY=
# Доп. фильтр CQL, например: label = "incident-playbook"
CONFLUENCE_CQL_PREFIX=
CONFLUENCE_TIMEOUT_SEC=60
CONFLUENCE_SEARCH_LIMIT=10
CONFLUENCE_SCORE_MIN=4
CONFLUENCE_PAGE_ANCHOR_MIN=2
LOG_ANCHOR_MIN=2
POC_ARTIFACT_SCAN_MAX_SAMPLES_PER_MATCH=3
POC_ARTIFACT_SCAN_MAX_DISCOVERED_ANCHORS=30
